OPENAI_API_KEY=
PIM_XLSX=
FAMILY_MAP_XLSX=
PIM_VERBOSE=1
USE_SQLITE=1
PRODUCT_DB_BACKEND=sqlite
PRODUCT_DB_PATH=data/products.db
PRODUCT_DATABASE_URL=
# Example PostgreSQL:
# PRODUCT_DB_BACKEND=postgres
# PRODUCT_DATABASE_URL=postgresql://user:password@localhost:5432/productfinder

# Security
ENABLE_DEBUG_ENDPOINTS=false
ADMIN_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth
AUTH_DB_PATH=data/auth.db
AUTH_DATABASE_URL=
# Example PostgreSQL:
# AUTH_DATABASE_URL=postgresql://user:password@localhost:5432/productfinder
AUTH_JWT_SECRET=change-me
AUTH_TOKEN_EXPIRE_MINUTES=120
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe1234
ADMIN_BOOTSTRAP_NAME=Administrator

# Rate limiting
RATE_LIMIT_STORE=shared
RATE_LIMIT_DATABASE_URL=

# Optional runtime limits
IMAGE_PARSE_MAX_BYTES=8388608
PDF_PARSE_MAX_UPLOAD_BYTES=10485760
