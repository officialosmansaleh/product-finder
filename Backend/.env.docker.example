OPENAI_API_KEY=
PIM_XLSX=
FAMILY_MAP_XLSX=
PIM_VERBOSE=1
USE_SQLITE=0
PRODUCT_DB_BACKEND=postgres

# App security
ENABLE_DEBUG_ENDPOINTS=false
ADMIN_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:8000

# Auth
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRE_MINUTES=120
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe1234
ADMIN_BOOTSTRAP_NAME=Administrator

# Rate limiting
RATE_LIMIT_STORE=shared
RATE_LIMIT_DATABASE_URL=

# Postgres service values used by docker-compose
POSTGRES_DB=productfinder
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Optional runtime limits
IMAGE_PARSE_MAX_BYTES=8388608
PDF_PARSE_MAX_UPLOAD_BYTES=10485760
